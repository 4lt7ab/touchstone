{
  "name": "@touchstone/molecules",
  "version": "0.0.1",
  "private": true,
  "description": "Atomic-design 'molecules' — small compositions of atoms (Field, ...).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.css.js"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "lint": "eslint src",
    "typecheck": "tsc -b --pretty",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@touchstone/atoms": "workspace:*",
    "@touchstone/hooks": "workspace:*",
    "@touchstone/themes": "workspace:*",
    "@vanilla-extract/css": "^1.15.3",
    "@vanilla-extract/recipes": "^0.5.3"
  },
  "devDependencies": {
    "@touchstone/tsconfig": "workspace:*",
    "@touchstone/tsup-config": "workspace:*",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vanilla-extract/vite-plugin": "^4.0.13",
    "jsdom": "^24.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.2.4",
    "typescript": "^5.5.3",
    "vitest": "^2.0.4"
  }
}
