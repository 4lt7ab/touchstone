{
  "name": "@touchstone/tokens",
  "version": "0.0.4",
  "description": "Raw design tokens (color, space, font, radius, z-index) for Touchstone.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo 'no tests'",
    "lint": "eslint src",
    "typecheck": "tsc -b --pretty",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "devDependencies": {
    "@touchstone/tsconfig": "workspace:*",
    "@touchstone/tsup-config": "workspace:*",
    "tsup": "^8.2.4",
    "typescript": "^5.5.3"
  }
}
