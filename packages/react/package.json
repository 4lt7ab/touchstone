{
  "name": "@4lt7ab/touchstone",
  "version": "0.0.1",
  "description": "Touchstone — a React component library that is the team's measure of quality.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/4lt7ab/touchstone.git"
  },
  "homepage": "https://github.com/4lt7ab/touchstone#readme",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css",
    "**/*.css.js"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "echo 'no tests'",
    "lint": "eslint src",
    "typecheck": "tsc -b --pretty",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0"
  },
  "dependencies": {
    "@vanilla-extract/css": "^1.15.3",
    "@vanilla-extract/recipes": "^0.5.3"
  },
  "devDependencies": {
    "@touchstone/atoms": "workspace:*",
    "@touchstone/hooks": "workspace:*",
    "@touchstone/icons": "workspace:*",
    "@touchstone/molecules": "workspace:*",
    "@touchstone/organisms": "workspace:*",
    "@touchstone/themes": "workspace:*",
    "@touchstone/tokens": "workspace:*",
    "@touchstone/tsconfig": "workspace:*",
    "@touchstone/tsup-config": "workspace:*",
    "@vanilla-extract/esbuild-plugin": "^2.3.13",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.2.4",
    "typescript": "^5.5.3"
  }
}
