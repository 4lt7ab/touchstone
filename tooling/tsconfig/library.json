{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "./base.json",
  "compilerOptions": {
    "composite": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": "${configDir}/src",
    "outDir": "${configDir}/dist",
    "incremental": true
  },
  "exclude": [
    "${configDir}/dist",
    "${configDir}/node_modules",
    "${configDir}/src/**/*.test.ts",
    "${configDir}/src/**/*.test.tsx",
    "${configDir}/src/**/*.stories.tsx"
  ]
}
